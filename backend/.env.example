# 🔐 Server Configuration
NODE_ENV=production
PORT=10000

# 🔑 JWT Secret — KUCHLI PAROL O'YLATING! (kamida 32 belgi)
# Render da avtomatik generatsiya qilinadi, local da o'zingiz yozing
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production-min-32-chars

# 🗄️ PostgreSQL Database URL
# Format: postgresql://user:password@host:port/database?schema=public
# Render da avtomatik beriladi, local da o'zingiz sozlang
DATABASE_URL=postgresql://postgres:password@localhost:5432/olaja_db?schema=public

# 🌐 CORS — Qaysi domainlardan ruxsat berish
# Production da: https://olajatort.uz,https://www.olajatort.uz
# Development da: * (hamma joydan)
CORS_ORIGIN=*

# 🖼️ Upload Settings
MAX_FILE_SIZE=5242880
UPLOAD_PATH=./uploads/cakes

# 📧 Email (kelajakda)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# 🔔 Push Notification (kelajakda)
FIREBASE_SERVICE_ACCOUNT_KEY=your-firebase-key.json
